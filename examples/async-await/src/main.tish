// Async/await + parallel HTTP (native / async entry)
import { fetchAll } from 'http'

console.log("Fetching URLs in parallel with fetchAll...")

let urls = [
    "https://httpbin.org/get",
    "https://httpbin.org/uuid",
    "https://httpbin.org/headers"
]

let results = await fetchAll(urls.map(u => ({ url: u })))
let allOk = results.every(r => r.ok)
console.log("All fetches ok:", allOk, "count:", results.length)
console.log("Done")
