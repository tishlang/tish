// Parallel: await fetchAll — all requests run concurrently (non-blocking)
import { fetchAll } from 'http'

let urls = [
    "https://httpbin.org/delay/1",
    "https://httpbin.org/delay/1",
    "https://httpbin.org/delay/1"
]
let results = await fetchAll(urls.map(u => ({ url: u })))
let allOk = results.every(r => r.ok)
console.log("Parallel:", results.length, "responses, all ok:", allOk)
