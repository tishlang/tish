// Sequential: await fetch in a loop — each blocks until done
import { fetch } from 'http'

let urls = [
    "https://httpbin.org/delay/1",
    "https://httpbin.org/delay/1",
    "https://httpbin.org/delay/1"
]
let i = 0
while (i < urls.length) {
    await fetch(urls[i])
    i = i + 1
}
console.log("Sequential: done", urls.length, "fetches")
