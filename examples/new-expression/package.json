{
  "name": "new-expression",
  "version": "0.1.0",
  "scripts": {
    "compile:js:node-patterns": "tish compile src/node-bun-new-patterns.tish --target js -o dist/node-bun-new.js",
    "verify:js:node": "npm run compile:js:node-patterns && node dist/node-bun-new.js",
    "verify:js:bun": "npm run compile:js:node-patterns && bun dist/node-bun-new.js"
  },
  "tish": {
    "source": "./src/main.tish"
  }
}
