{
  "name": "tish-npm-packages",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "tish-npm-packages",
      "workspaces": [
        "tish",
        "create-tish-app"
      ]
    },
    "create-tish-app": {
      "name": "@tishlang/create-tish-app",
      "version": "0.1.0",
      "license": "PIF",
      "bin": {
        "create-tish-app": "index.js"
      },
      "engines": {
        "node": ">=14"
      }
    },
    "node_modules/@tishlang/create-tish-app": {
      "resolved": "create-tish-app",
      "link": true
    },
    "node_modules/@tishlang/tish": {
      "resolved": "tish",
      "link": true
    },
    "tish": {
      "name": "@tishlang/tish",
      "version": "1.0.12",
      "hasInstallScript": true,
      "license": "PIF",
      "bin": {
        "tish": "bin/tish"
      },
      "engines": {
        "node": ">=22"
      }
    }
  }
}
