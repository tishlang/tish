// --- types (checker / editor; no runtime effect) ---

type AnyFn = (any) => any

declare let console: {
  debug: AnyFn,
  info: AnyFn,
  log: AnyFn,
  warn: AnyFn,
  error: AnyFn,
}

declare const Math: {
  abs: AnyFn,
  sqrt: AnyFn,
  min: AnyFn,
  max: AnyFn,
  floor: AnyFn,
  ceil: AnyFn,
  round: AnyFn,
  random: AnyFn,
  pow: AnyFn,
  sin: AnyFn,
  cos: AnyFn,
  tan: AnyFn,
  log: AnyFn,
  exp: AnyFn,
  sign: AnyFn,
  trunc: AnyFn,
  PI: number,
  E: number,
}

declare const JSON: {
  parse: AnyFn,
  stringify: AnyFn,
}

declare const Object: {
  keys: AnyFn,
  values: AnyFn,
  entries: AnyFn,
  assign: AnyFn,
  fromEntries: AnyFn,
}

declare const Array: {
  isArray: AnyFn,
}

declare const String: {
  fromCharCode: AnyFn,
}

declare const Date: {
  now: AnyFn,
}

declare let parseInt: AnyFn
declare let parseFloat: AnyFn
declare let decodeURI: AnyFn
declare let encodeURI: AnyFn
declare let Boolean: AnyFn
declare let isFinite: AnyFn
declare let isNaN: AnyFn
declare const Infinity: number
declare const NaN: number

declare let Uint8Array: any
declare let AudioContext: any
declare let RegExp: any

declare function setTimeout(callback: any, delay: number): number
declare function setInterval(callback: any, delay: number): number
declare function clearTimeout(id: number): void
declare function clearInterval(id: number): void
