// `delete` operator removes object properties / array elements (issue #40).
// Presence is checked with `in` (and a falsy read) so assertions are identical across
// backends — tish has no `undefined`, and a deleted slot reads back as null.
let o = { a: 1, b: 2, c: 3 }
let r = delete o.a
console.log(r)
console.log("a" in o)
console.log("b" in o)
delete o["b"]
console.log("b" in o)
console.log("c" in o)
let a = [10, 20, 30]
delete a[1]
console.log(a.length)
console.log(!a[1])
console.log(a[0], a[2])
