// Regression tests for fixes found via tests/core/jit_probe (numeric JIT,
// object layout, JSON). Output uses join/JSON/scalars so it is byte-identical
// across tish backends AND Node (no array-print formatting differences).
// If this file's expected output changes, a fix has regressed.
let a = [1, 2, 3, 4, 5];

// --- numeric JIT: comparison callbacks must box as BOOL, not Number ---
// (regression: map(x => x === c) returned [0,1,..] instead of [false,true,..])
console.log(a.map(x => x === 3).join(","));        // false,false,true,false,false
console.log(a.map(x => x > 2).join(","));          // false,false,true,true,true
console.log(a.map(x => x <= 2).join(","));         // true,true,false,false,false
console.log(a.map(x => x % 2 === 0).join(","));    // false,true,false,true,false
console.log(a.map(x => !(x === 3)).join(","));     // true,true,false,true,true

// --- numeric (non-bool) callbacks stay Number ---
console.log(a.map(x => x * 2).join(","));          // 2,4,6,8,10
console.log(a.map(x => x - 1).join(","));          // 0,1,2,3,4
console.log(a.map(x => 0 - x).join(","));          // -1,-2,-3,-4,-5

// --- mod in the JIT (a - trunc(a/b)*b, matches Rust % and Node) ---
console.log([15, 7, 0, 8, 22].map(x => x % 7).join(","));   // 1,0,0,1,1
console.log([10, 9, 8].map(x => x % 3).join(","));          // 1,0,2

// --- find/some/every truthiness via comparison callbacks (JIT path) ---
console.log(a.find(x => x === 4));                 // 4
console.log(a.some(x => x > 4));                   // true
console.log(a.every(x => x < 10));                 // true
console.log(a.filter(x => x % 2 === 1).join(","));  // 1,3,5

// --- numeric reduce (JIT path) ---
console.log(a.reduce((s, x) => s + x, 0));         // 15
console.log(a.reduce((s, x) => s + x * x, 0));     // 55

// --- loose ==/!= behave as strict, consistent across all backends (was an interp error) ---
console.log((1 == 1) + "," + (2 == 2) + "," + (1 == 2) + "," + ("a" == "a") + "," + (1 != 2));  // true,true,false,true,true

// --- object key order: insertion order (PropMap), matches JS/Node ---
// (regression: was hash order; JSON used to sort keys alphabetically)
let o = { id: 5, name: "x", active: true };
console.log(Object.keys(o).join(","));             // id,name,active
console.log(JSON.stringify(o));                    // {"id":5,"name":"x","active":true}
console.log(JSON.stringify({ b: 1, a: 2, c: 3 })); // {"b":1,"a":2,"c":3}
console.log(o.id + "," + o.name + "," + o.active); // 5,x,true

// --- larger object: >8 keys promotes to IndexMap, still insertion order ---
let big = { z: 1, y: 2, x: 3, w: 4, v: 5, u: 6, t: 7, s: 8, r: 9, q: 10 };
console.log(JSON.stringify(big));                  // {"z":1,...,"q":10}
console.log(Object.keys(big).join(","));           // z,y,x,w,v,u,t,s,r,q
