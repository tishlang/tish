// Test extended Math functions

// Constants
console.log("Math.PI:", Math.PI > 3.14 && Math.PI < 3.15)
console.log("Math.E:", Math.E > 2.71 && Math.E < 2.72)

// Math.pow
console.log("Math.pow(2, 3):", Math.pow(2, 3))
console.log("Math.pow(10, 0):", Math.pow(10, 0))
console.log("Math.pow(4, 0.5):", Math.pow(4, 0.5))

// Math.random - should return different values
let r1 = Math.random()
let r2 = Math.random()
console.log("random() returns number:", typeof r1 === "number")
console.log("random() in range [0,1):", r1 >= 0 && r1 < 1)

// Trig functions (using PI for known values)
let sinPiHalf = Math.sin(Math.PI / 2)
console.log("Math.sin(PI/2) ~= 1:", sinPiHalf > 0.99 && sinPiHalf <= 1)

let cosZero = Math.cos(0)
console.log("Math.cos(0) = 1:", cosZero === 1)

let tanZero = Math.tan(0)
console.log("Math.tan(0) = 0:", tanZero === 0)

// Math.log and Math.exp
console.log("Math.log(1):", Math.log(1))
console.log("Math.log(Math.E):", Math.log(Math.E) > 0.99 && Math.log(Math.E) < 1.01)
console.log("Math.exp(0):", Math.exp(0))
console.log("Math.exp(1) ~= E:", Math.exp(1) > 2.71 && Math.exp(1) < 2.72)

// Math.sign
console.log("Math.sign(5):", Math.sign(5))
console.log("Math.sign(-5):", Math.sign(-5))
console.log("Math.sign(0):", Math.sign(0))

// Math.trunc
console.log("Math.trunc(4.7):", Math.trunc(4.7))
console.log("Math.trunc(-4.7):", Math.trunc(-4.7))
console.log("Math.trunc(0.5):", Math.trunc(0.5))

// Hyperbolic / inverse-hyperbolic / cbrt / log2 / log10 (issue #61)
console.log("Math.sinh(0):", Math.sinh(0))
console.log("Math.cosh(0):", Math.cosh(0))
console.log("Math.tanh(0):", Math.tanh(0))
console.log("Math.asinh(0):", Math.asinh(0))
console.log("Math.acosh(1):", Math.acosh(1))
console.log("Math.atanh(0):", Math.atanh(0))
console.log("Math.cbrt(27):", Math.cbrt(27))
console.log("Math.log2(8):", Math.log2(8))
console.log("Math.log10(1000):", Math.log10(1000))
