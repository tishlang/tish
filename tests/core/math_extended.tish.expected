Math.PI: true
Math.E: true
Math.pow(2, 3): 8
Math.pow(10, 0): 1
Math.pow(4, 0.5): 2
random() returns number: true
random() in range [0,1): true
Math.sin(PI/2) ~= 1: true
Math.cos(0) = 1: true
Math.tan(0) = 0: true
Math.log(1): 0
Math.log(Math.E): true
Math.exp(0): 1
Math.exp(1) ~= E: true
Math.sign(5): 1
Math.sign(-5): -1
Math.sign(0): 0
Math.trunc(4.7): 4
Math.trunc(-4.7): -4
Math.trunc(0.5): 0
Math.sinh(0): 0
Math.cosh(0): 1
Math.tanh(0): 0
Math.asinh(0): 0
Math.acosh(1): 0
Math.atanh(0): 0
Math.cbrt(27): 3
Math.log2(8): 3
Math.log10(1000): 3
