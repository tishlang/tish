// #176: top-level numeric globals lower to thread_local Cell<f64>; boxed and native callers share state.
let counter = 10

function bump() {
  counter = (counter * 3 + 7) % 1000
  return counter
}

function read() {
  return counter
}

function run() {
  let a = bump()
  let b = read()
  let c = bump()
  return a * 10000 + b * 100 + c
}

console.log("native_numeric_global " + run())
