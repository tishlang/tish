// Complex nested loops, scopes, and functions test

// === NESTED LOOPS ===

// Triple nested for loops - matrix traversal
let sum = 0
for (let i = 0; i < 3; i = i + 1) {
    for (let j = 0; j < 3; j = j + 1) {
        for (let k = 0; k < 3; k = k + 1) {
            sum = sum + (i * 9 + j * 3 + k)
        }
    }
}
console.log("Triple nested sum:", sum)

// Mixed loop types nested
let result = 0
let outer = 0
while (outer < 3) {
    for (let mid = 0; mid < 3; mid = mid + 1) {
        let inner = 0
        while (inner < 3) {
            result = result + 1
            inner = inner + 1
        }
    }
    outer = outer + 1
}
console.log("Mixed loops count:", result)

// Nested for-of loops
let matrix = [[1, 2], [3, 4], [5, 6]]
let matrixSum = 0
for (let row of matrix) {
    for (let cell of row) {
        matrixSum = matrixSum + cell
    }
}
console.log("Matrix sum:", matrixSum)

// Nested loops with break/continue
let breakSum = 0
for (let i = 0; i < 5; i = i + 1) {
    for (let j = 0; j < 5; j = j + 1) {
        if (j === 3) {
            continue
        }
        if (i === 3 && j === 2) {
            break
        }
        breakSum = breakSum + 1
    }
}
console.log("Break/continue sum:", breakSum)

// === NESTED SCOPES ===

// Variable shadowing across scopes
let x = 1
{
    let x = 2
    {
        let x = 3
        {
            let x = 4
            console.log("Innermost x:", x)
        }
        console.log("Third level x:", x)
    }
    console.log("Second level x:", x)
}
console.log("Outer x:", x)

// Accessing outer scope variables
let a = 10
let b = 20
{
    let c = a + b
    {
        let d = c + a
        {
            let e = d + b + c
            console.log("Deep access:", e)
        }
    }
}

// Scope with loops
let loopScoped = 0
for (let i = 0; i < 3; i = i + 1) {
    let blockVar = i * 10
    {
        let innerVar = blockVar + i
        loopScoped = loopScoped + innerVar
    }
}
console.log("Loop scoped:", loopScoped)

// === NESTED FUNCTIONS ===

// Simple nested function
fn outerFunc(n) {
    fn inner(m) {
        return m * 2
    }
    return inner(n) + n
}
console.log("Nested func:", outerFunc(5))

// Nested function accessing outer scope (called within parent)
fn computeWithHelper(base, multiplier) {
    fn helper(x) {
        return base + (x * multiplier)
    }
    let r1 = helper(1)
    let r2 = helper(2)
    let r3 = helper(3)
    return r1 + r2 + r3
}
console.log("Helper result:", computeWithHelper(10, 5))

// Multiple levels of nested functions
fn level1(a) {
    fn level2(b) {
        fn level3(c) {
            fn level4(d) {
                return a + b + c + d
            }
            return level4(4)
        }
        return level3(3)
    }
    return level2(2)
}
console.log("4 level nesting:", level1(1))

// Recursive nested function
fn fibonacci(n) {
    fn fib(a, b, remaining) {
        if (remaining === 0) {
            return a
        }
        return fib(b, a + b, remaining - 1)
    }
    return fib(0, 1, n)
}
console.log("Fib 10:", fibonacci(10))

// Mutually referencing nested functions
fn isEvenOdd(n) {
    fn isEven(x) {
        if (x === 0) return true
        return isOdd(x - 1)
    }
    fn isOdd(x) {
        if (x === 0) return false
        return isEven(x - 1)
    }
    return isEven(n)
}
console.log("Is 10 even?", isEvenOdd(10))
console.log("Is 7 even?", isEvenOdd(7))

// === COMBINED: LOOPS + SCOPES + FUNCTIONS ===

// Function with nested loops and scopes
fn processMatrix(mat) {
    let total = 0
    for (let row of mat) {
        let rowSum = 0
        {
            for (let val of row) {
                rowSum = rowSum + val
            }
        }
        total = total + rowSum
    }
    return total
}
console.log("Process matrix:", processMatrix([[1, 2, 3], [4, 5, 6], [7, 8, 9]]))

// Function with nested helper called in loop
fn sumWithTransform(arr, offset) {
    fn transform(val) {
        return val * 2 + offset
    }
    let total = 0
    for (let item of arr) {
        total = total + transform(item)
    }
    return total
}
console.log("Transform sum:", sumWithTransform([1, 2, 3, 4, 5], 10))

// Complex accumulator with nested everything
fn complexAccumulator(data) {
    let result = 0
    
    fn processItem(item) {
        let itemResult = 0
        if (typeof item === "number") {
            return item
        }
        for (let subItem of item) {
            {
                let processed = processItem(subItem)
                itemResult = itemResult + processed
            }
        }
        return itemResult
    }
    
    for (let item of data) {
        {
            let contribution = processItem(item)
            result = result + contribution
        }
    }
    return result
}
console.log("Complex accum:", complexAccumulator([1, [2, 3], [[4, 5], 6], 7]))

// Nested conditionals with scopes
fn nestedConditional(x) {
    let result = "none"
    if (x > 0) {
        let sign = "positive"
        if (x > 10) {
            let size = "large"
            if (x > 100) {
                result = sign + "-" + size + "-huge"
            } else {
                result = sign + "-" + size
            }
        } else {
            result = sign + "-small"
        }
    } else {
        if (x < 0) {
            result = "negative"
        } else {
            result = "zero"
        }
    }
    return result
}
console.log("Cond 0:", nestedConditional(0))
console.log("Cond 5:", nestedConditional(5))
console.log("Cond 50:", nestedConditional(50))
console.log("Cond 150:", nestedConditional(150))
console.log("Cond -5:", nestedConditional(-5))

// Performance stress: deeply nested computation
fn deepCompute(depth, value) {
    if (depth === 0) {
        return value
    }
    let accumulated = 0
    for (let i = 0; i < 3; i = i + 1) {
        {
            let partial = deepCompute(depth - 1, value + i)
            accumulated = accumulated + partial
        }
    }
    return accumulated
}
console.log("Deep compute:", deepCompute(4, 1))

console.log("All nested tests passed!")
