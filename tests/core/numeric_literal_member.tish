// Member access / method calls directly on a numeric literal must compile to valid JS:
// `(255).toFixed(0)`, not `255.toFixed(0)` — a bare integer followed by `.` lexes the dot
// as the start of a fraction, a SyntaxError on the JS target. Found while fixing #59.
console.log((255).toFixed(0))
console.log((255).toFixed(2))
console.log((3735928559).toFixed(0))
console.log((3.14159).toFixed(2))
console.log((0).toFixed(0))
console.log("v=" + (10).toFixed(1))
let label = "n=" + (42).toFixed(0)
console.log(label)
