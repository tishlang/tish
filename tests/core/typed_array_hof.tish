// Native typed-array HOFs (opt-in via TISH_NATIVE_HOF): `reduce`/`map`/`filter`/`some`/`every`
// over a `number[]` (Vec<f64>) lower to a direct Rust iterator chain — no per-element `value_call`,
// no `Value` boxing. Output is identical to the boxed path on every backend, flags on or off.

let xs: number[] = [3, 1, 4, 1, 5, 9, 2, 6]

// reduce: sum and product (the canonical numeric-accumulation hot path).
let sum: number = xs.reduce((a, b) => a + b, 0)
console.log(sum)
let prod: number = xs.reduce((a, b) => a * b, 1)
console.log(prod)

// map: double each element, then fold to a deterministic scalar.
let doubled: number[] = xs.map(x => x * 2)
console.log(doubled.reduce((a, b) => a + b, 0))

// filter: keep elements > 3.
let big: number[] = xs.filter(x => x > 3)
console.log(big.length)
console.log(big.reduce((a, b) => a + b, 0))

// some / every: short-circuiting predicates.
let hasBig: boolean = xs.some(x => x > 8)
console.log(hasBig)
let allPos: boolean = xs.every(x => x > 0)
console.log(allPos)
let allBig: boolean = xs.every(x => x > 3)
console.log(allBig)

// Guard: an untyped array still runs correctly via the boxed HOF path.
let ys = [10, 20, 30]
console.log(ys.reduce((a, b) => a + b, 0))
