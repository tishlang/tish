// HTTP throughput benchmark fixture (DB-free) — driven by scripts/run_http_perf.sh.
//
// Isolates the multi-worker HTTP server + per-request VM handler dispatch (the
// `send-values` / multi-threaded path that the single-shot core/* perf tests never
// exercise). Routes mirror the TechEmpower plaintext + json workloads:
//   GET /plaintext -> 13-byte text body
//   GET /json      -> JSON.stringify per request (serialization on the hot path)
//
// Runs forever with prefork multi-worker by default. Control with:
//   PORT               listen port (default 8080)
//   TISH_HTTP_WORKERS  worker count (default = num_cpus)
//   TISH_HTTP_PREFORK  0 to force single process
import { serve } from 'http'

fn handleRequest(req) {
    if (req.path === "/plaintext") {
        return {
            status: 200,
            headers: { "content-type": "text/plain" },
            body: "Hello, World!"
        }
    }
    if (req.path === "/json") {
        return {
            status: 200,
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ message: "Hello, World!" })
        }
    }
    return { status: 404, body: "Not Found" }
}

let port = "PORT" in process.env ? parseInt(process.env.PORT) : 8080
serve(port, handleRequest)
