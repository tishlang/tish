// === SORTING ===
console.log("");
console.log("--- Sorting ---");

fn shuffle(arr) {
    let result = [...arr];
    for (let ii = result.length - 1; ii > 0; ii--) {
        let j = Math.floor(Math.random() * (ii + 1));
        let temp = result[ii];
        result[ii] = result[j];
        result[j] = temp;
    }
    return result;
}

