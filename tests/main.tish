fn __perf_run_core_forof_empty() {
// Regression: `for-of` over an EMPTY array must run the body zero times. The
// bytecode VM used to bottom-test the loop, so an empty array ran the body once
// (reading arr[0] -> null) and `continue` skipped the increment (infinite loop).

// empty array literal: body never runs
let total = 0
for (let x of []) { total = total + x }
console.log(total)

// empty array via a variable
let empty = []
let ran = false
for (let x of empty) { ran = true }
console.log(ran)

// `continue` reaches the increment (was: infinite loop)
let kept = []
for (let x of [1, 2, 3, 4]) {
  if (x === 2) { continue }
  kept.push(x)
}
console.log(kept.join(","))

// `break` still exits
let firsts = []
for (let x of [5, 6, 7]) {
  if (x === 7) { break }
  firsts.push(x)
}
console.log(firsts.join(","))

// empty inner loop inside a non-empty outer loop
let acc = 0
for (let i of [1, 2, 3]) {
  for (let j of []) { acc = acc + 100 }
  acc = acc + i
}
console.log(acc)
}
__perf_run_core_forof_empty()

fn __perf_run_core_higher_order_methods() {
// Test higher-order array methods

let nums = [1, 2, 3, 4, 5]

// Define callback functions
fn double(x) { return x * 2 }
fn isEven(x) { return x % 2 === 0 }
fn add(acc, x) { return acc + x }
fn gtThree(x) { return x > 3 }
fn gtZero(x) { return x > 0 }
fn isThree(x) { return x === 3 }
fn ltThree(x) { return x < 3 }

// map
let doubled = nums.map(double)
console.log("map:", doubled.join(","))

// filter
let evens = nums.filter(isEven)
console.log("filter:", evens.join(","))

// reduce with initial value
let sum = nums.reduce(add, 0)
console.log("reduce:", sum)

// reduce without initial value
fn multiply(acc, x) { return acc * x }
let product = nums.reduce(multiply)
console.log("reduce (no init):", product)

// find
let found = nums.find(gtThree)
console.log("find:", found)

// find returns null when not found
fn gtHundred(x) { return x > 100 }
let notFound = nums.find(gtHundred)
console.log("find (not found):", notFound)

// findIndex
let foundIdx = nums.findIndex(gtThree)
console.log("findIndex:", foundIdx)

// findIndex returns -1 when not found
let notFoundIdx = nums.findIndex(gtHundred)
console.log("findIndex (not found):", notFoundIdx)

// some
console.log("some (> 3):", nums.some(gtThree))
console.log("some (> 100):", nums.some(gtHundred))

// every
console.log("every (> 0):", nums.every(gtZero))
console.log("every (> 3):", nums.every(gtThree))

// forEach
let total = 0
fn addToTotal(x) { total = total + x }
nums.forEach(addToTotal)
console.log("forEach total:", total)

// flat
let nested = [1, [2, 3], [4, [5, 6]]]
console.log("flat(1):", nested.flat().map(x => Array.isArray(x) ? "[" + x.join(", ") + "]" : x).join(","))
console.log("flat(2):", nested.flat(2).join(","))

// Chaining
let result = [1, 2, 3, 4, 5, 6]
    .filter(isEven)
    .map(double)
console.log("chained:", result.join(","))
}
__perf_run_core_higher_order_methods()

