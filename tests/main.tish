fn __perf_run_core_typed_array_forof() {
// M3: `for (let x of xs)` over a typed array iterates natively (index-based over the Vec, no
// per-element boxing) and the accumulator stays native. Output is identical to the boxed path on
// every backend, with or without the typing flags.

let xs: number[] = [3, 1, 4, 1, 5, 9, 2, 6]
let total: number = 0
for (let x of xs) { total = total + x }
console.log(total)

let prod: number = 1
for (let x of xs) { prod = prod * x }
console.log(prod)

// string[] -> Vec<String>: native element type, so it iterates natively too (concat uses M2).
let words: string[] = ["a", "b", "c"]
let joined: string = ""
for (let w of words) { joined = joined + w }
console.log(joined)

// Guard: an untyped array still iterates correctly via the boxed path.
let ys = [10, 20, 30]
let s = 0
for (let y of ys) { s = s + y }
console.log(s)
}
__perf_run_core_typed_array_forof()

fn __perf_run_core_typed_array_hof() {
// Native typed-array HOFs (opt-in via TISH_NATIVE_HOF): `reduce`/`map`/`filter`/`some`/`every`
// over a `number[]` (Vec<f64>) lower to a direct Rust iterator chain — no per-element `value_call`,
// no `Value` boxing. Output is identical to the boxed path on every backend, flags on or off.

let xs: number[] = [3, 1, 4, 1, 5, 9, 2, 6]

// reduce: sum and product (the canonical numeric-accumulation hot path).
let sum: number = xs.reduce((a, b) => a + b, 0)
console.log(sum)
let prod: number = xs.reduce((a, b) => a * b, 1)
console.log(prod)

// map: double each element, then fold to a deterministic scalar.
let doubled: number[] = xs.map(x => x * 2)
console.log(doubled.reduce((a, b) => a + b, 0))

// filter: keep elements > 3.
let big: number[] = xs.filter(x => x > 3)
console.log(big.length)
console.log(big.reduce((a, b) => a + b, 0))

// some / every: short-circuiting predicates.
let hasBig: boolean = xs.some(x => x > 8)
console.log(hasBig)
let allPos: boolean = xs.every(x => x > 0)
console.log(allPos)
let allBig: boolean = xs.every(x => x > 3)
console.log(allBig)

// Guard: an untyped array still runs correctly via the boxed HOF path.
let ys = [10, 20, 30]
console.log(ys.reduce((a, b) => a + b, 0))
}
__perf_run_core_typed_array_hof()

fn __perf_run_core_typed_array_literal_infer() {
// Array-literal element inference (opt-in via TISH_STRUCT_INFER): a read-only `let xs = [scalars]`
// used only in for-of / `.length` infers a native `T[]`. Output is identical with or without the
// flag and across backends; mutation or index-read keeps the array boxed (sound), so behavior never
// changes — this fixture just exercises the inferred-native path.

let nums = [10, 20, 30, 40]
let total = 0
for (let n of nums) { total = total + n }
console.log(total)
console.log(nums.length)

let names = ["a", "b", "c"]
let joined = ""
for (let s of names) { joined = joined + s }
console.log(joined)
}
__perf_run_core_typed_array_literal_infer()

fn __perf_run_core_typed_array_of_structs() {
// M3 member-on-non-ident: `pts[i].x` (indexing a typed array of structs) lowers to native struct
// field access, not a dynamic `get_prop`; iterating `Point[]` binds the loop var to the struct
// type so `p.x` is native too. Output identical across backends.

type Point = { x: number, y: number }

let pts: Point[] = [{ x: 1, y: 2 }, { x: 3, y: 4 }, { x: 5, y: 6 }]
console.log(pts[0].x)
console.log(pts[2].y)

let sum: number = 0
for (let p of pts) { sum = sum + p.x + p.y }
console.log(sum)
}
__perf_run_core_typed_array_of_structs()

fn __perf_run_core_typed_arrays() {
// Typed arrays — constructors, element coercion, statics, indexing, length, and iteration, identical
// across interp / VM / native / node. Coercion happens at construction (`new`, `.from`, `.of`); the
// backing is a plain array so indexing / `.length` / `for…of` / array methods all work. Outputs are
// elements/scalars (never the array object) so nothing depends on typed-array display formatting.

// Float32: rounds to f32 precision (0.1 is not representable in f32).
let f32 = new Float32Array([1.5, 0.1])
console.log(f32.length)
console.log(f32[0])              // 1.5 (exact)
console.log(f32[1] === 0.1)     // false — stored as the f32-rounded double
console.log(f32[1] < 0.1001 && f32[1] > 0.0999)  // true

// Float64: exact.
let f64 = new Float64Array([1.1, 2.2])
console.log(f64[0], f64[1])

// Uint8: truncate + wrap mod 256.
let u8 = new Uint8Array([300, -1, 256, 7, 3.9])
console.log(u8[0], u8[1], u8[2], u8[3], u8[4])   // 44 255 0 7 3

// Int8: signed wrap.
let i8 = new Int8Array([127, 128, -129, 256])
console.log(i8[0], i8[1], i8[2], i8[3])          // 127 -128 127 0

// Uint8Clamped: clamp to 0..255, round half to even.
let c = new Uint8ClampedArray([-5, 300, 2.5, 3.5, 0.5])
console.log(c[0], c[1], c[2], c[3], c[4])        // 0 255 2 4 0

// 16/32-bit wraps.
console.log(new Int16Array([32768, -32769])[0], new Int16Array([-32769])[0])  // -32768 32767
console.log(new Uint16Array([65536, 65537])[0], new Uint16Array([65537])[0])  // 0 1
console.log(new Int32Array([2147483648])[0])     // -2147483648
console.log(new Uint32Array([4294967296, 4294967297])[1])  // 1

// Length constructor → zero-filled.
let z = new Uint16Array(4)
console.log(z.length, z[0], z[3])                // 4 0 0

// Non-numeric → NaN → 0 for integer views.
let n = new Int32Array([null, "x"])
console.log(n[0], n[1])                          // 0 0

// Statics.
console.log(Uint8Array.of(1, 2, 300)[2])         // 44
console.log(Int32Array.from([1.9, 2.9, 3.9])[1]) // 2
console.log(Uint8Array.BYTES_PER_ELEMENT)        // 1
console.log(Float64Array.BYTES_PER_ELEMENT)      // 8
console.log(Int32Array.BYTES_PER_ELEMENT)        // 4

// Iteration + array methods (it's a real array underneath).
let sum = 0
for (let x of new Uint8Array([10, 20, 30])) { sum = sum + x }
console.log(sum)                                 // 60
console.log(new Float64Array([1, 2, 3, 4]).reduce((a, b) => a + b, 0))  // 10
}
__perf_run_core_typed_arrays()

fn __perf_run_core_typed_generic_mono() {
// Generic-struct monomorphization: `Box<number>` / `Pair<A,B>` specialize to concrete native
// structs (a `Box<number>` has an `f64` field, not a boxed Value). Output identical everywhere.
type Box<T> = { value: T }
let b: Box<number> = { value: 42 }
console.log(b.value + 1)
let s: Box<string> = { value: "hi" }
console.log(s.value)
interface Pair<A, B> { first: A, second: B }
let p: Pair<number, string> = { first: 7, second: "x" }
console.log(p.first)
console.log(p.second)
}
__perf_run_core_typed_generic_mono()

fn __perf_run_core_typed_generics() {
// Generics: `<T>` on functions / type aliases / refs. Type params are erased (gradual): generic
// code type-checks leniently and runs correctly; `Array<T>` desugars to the native `T[]`.
fn identity<T>(x: T): T { return x }
console.log(identity(5))
console.log(identity("hi"))
fn first<T>(xs: T[]): T { return xs[0] }
let a: number[] = [10, 20, 30]
console.log(first(a))
type Box<T> = { value: T }
let b: Box<number> = { value: 42 }
console.log(b.value)
let arr: Array<number> = [1, 2, 3]
console.log(arr[1])
console.log(arr.length)
}
__perf_run_core_typed_generics()

fn __perf_run_core_typed_intersection() {
// Intersection `A & B`, `interface extends`, and nested generics `Array<Array<T>>`.
let m: Array<Array<number>> = [[1, 2], [3, 4]]
console.log(m[0][1])
interface Named { name: string }
interface Aged { age: number }
type Person = Named & Aged
let p: Person = { name: "x", age: 30 }
console.log(p.name)
console.log(p.age)
interface Animal { legs: number }
interface Dog extends Animal { bark: boolean }
let d: Dog = { legs: 4, bark: true }
console.log(d.legs)
console.log(d.bark)
}
__perf_run_core_typed_intersection()

fn __perf_run_core_typed_param_loopbound() {
// M4 (TISH_PARAM_INFER): a param used as a loop bound (compared to a numeric local `i`) is
// inferred `: number`, so it lowers to a native f64 param. A param used as a STRING (concat) is
// NOT inferred — it stays dynamic. Output is identical with or without inference, every backend.

fn countUp(n) {
  let total = 0
  for (let i = 0; i < n; i = i + 1) {
    total = total + i
  }
  return total
}
console.log(countUp(10))
console.log(countUp(100))
console.log(countUp(0))

// Soundness guard: `x` is the bare operand of `+` against a string literal, so it is NOT provably
// numeric and must stay dynamic — otherwise `label("hi")` would mistype.
fn label(x) {
  return "v=" + x
}
console.log(label(5))
console.log(label("hi"))
}
__perf_run_core_typed_param_loopbound()

fn __perf_run_core_typed_rest_params() {
// M3 rest-params: `...args: number[]` lowers to a native `Vec<f64>` (each trailing arg unboxed),
// so the for-of reduction over it is fully native (loop var `f64`, accumulator stays `f64`).
// Output is identical across backends. (Empty-call cases are omitted: a separate pre-existing
// interp/VM bug mis-binds an empty rest-param — tracked elsewhere.)

fn sum(...args: number[]): number {
  let total: number = 0
  for (let n of args) { total = total + n }
  return total
}
console.log(sum(1, 2, 3, 4, 5))
console.log(sum(10, 20))

fn maxOf(...xs: number[]): number {
  let m: number = 0
  for (let x of xs) { if (x > m) { m = x } }
  return m
}
console.log(maxOf(3, 9, 2, 7))

// fixed params before the rest, all numeric
fn scaledSum(k: number, ...rest: number[]): number {
  let acc: number = 0
  for (let r of rest) { acc = acc + r * k }
  return acc
}
console.log(scaledSum(2, 1, 2, 3))
}
__perf_run_core_typed_rest_params()

fn __perf_run_core_typed_strings() {
// M2: typed native string concatenation + value equality.
// `: string` annotations lower these to native Rust `String` (no boxed Value) on the
// `--native-backend rust` path: `+` becomes a `format!`, `===`/`!==` compare by value.
// Output must be identical across interpreter / VM / native, flags on or off.

let a: string = "foo"
let b: string = "bar"

// concatenation
console.log(a + b)
console.log(a + b + a)
console.log(a + " " + b)

// value equality
console.log(a + b === "foobar")
console.log(a === "foo")
console.log(a !== b)
console.log(a === b)

// typed string parameters (native shadows under TISH_PARAM_NATIVE; boxed otherwise — same output)
fn join(x: string, y: string): string {
  return x + y
}
console.log(join("hello", "world"))
console.log(join(a, b) === "foobar")

// boundary: string + number must stay correct (boxed JS coercion, not native concat)
let n: number = 3
console.log("count=" + n)
console.log(a + n)
}
__perf_run_core_typed_strings()

fn __perf_run_core_typed_surface() {
// Optional `T?`, literal types, tuple types, and `as` casts.
let x: number? = 5
console.log(x)
let y: string? = null
console.log(y)
type Status = "on" | "off"
let s: Status = "on"
console.log(s)
let pair: [number, string] = [7, "z"]
console.log(pair[0])
console.log(pair[1])
let n = (42 as number) + 8
console.log(n)
}
__perf_run_core_typed_surface()

fn __perf_run_core_typeof() {
// MVP test: typeof operator
console.log(typeof 1)
console.log(typeof "hi")
console.log(typeof true)
console.log(typeof null)
console.log(typeof [1, 2])
console.log(typeof { a: 1 })
fn f() { return 1 }
console.log(typeof f)
}
__perf_run_core_typeof()

fn __perf_run_core_types() {
// Type annotation tests - parsed but not enforced (Phase 2)

// Simple type annotations
let x: number = 42
let name: string = "hello"
let flag: boolean = true
let empty: null = null

// Array types
let nums: number[] = [1, 2, 3]
let strs: string[] = ["a", "b", "c"]

// Function with typed parameters and return type
fn add(a: number, b: number): number {
    return a + b
}

// Function returning void
fn greet(msg: string): void {
    console.log(msg)
}

// Verify values work
console.log(add(x, 10))
greet("Welcome!")
console.log(name)
console.log(nums[1])

// Const with type
const PI: number = 3.14159
console.log(PI)

// Object type annotation
let person: { name: string, age: number } = { name: "Alice", age: 30 }
console.log(person.name)

// Union types
let value: number | string = 42
console.log(value)

// Function with rest params typed
fn sum(...args: number[]): number {
    let total: number = 0
    for (let n of args) {
        total = total + n
    }
    return total
}
console.log(sum(1, 2, 3, 4, 5))
}
__perf_run_core_types()

fn __perf_run_core_unsigned_right_shift() {
// `>>>` unsigned right shift + the bitwise family with JS ToInt32/ToUint32 (modulo 2^32,
// not a saturating cast) — exact across interp / VM / native / node, incl. large hash values.
console.log(-1 >>> 0)
console.log(-1 >>> 1)
console.log(256 >>> 4)
console.log(5 >>> 0)
console.log(4294967295 >>> 0)
console.log(1 << 4)
console.log(-8 >> 1)
console.log(1 << 35)
console.log(255 & 4294967295)
console.log(2166136261 ^ 16777619)
console.log((2166136261 * 16777619) >>> 0)
console.log(~0)
console.log(~5)
console.log(5 >>> -1)
// FNV-1a-style hashing loop: every op stays in the uint32 range via `>>> 0`.
function hash(n) {
  let h = 2166136261
  for (let i = 0; i < n; i++) {
    h = h ^ (i & 255)
    h = (h * 16777619) >>> 0
    h = (h << 13) | (h >>> 19)
  }
  return h >>> 0
}
console.log(hash(1000))
// ToInt32 / ToUint32 are MODULO 2^32 (not a saturating cast) — the whole point of the fix.
console.log((4294967296 + 5) | 0)   // 2^32 wraps to 0, +5 -> 5
console.log(4294967296 & 1)         // ToInt32(2^32)=0 -> 0
console.log(4294967297 & 1)         // ToInt32(2^32+1)=1 -> 1
console.log(4294967296 >>> 0)       // ToUint32(2^32)=0
console.log(3.9 | 0)                // truncate toward zero -> 3
console.log(-3.9 | 0)               // -> -3
console.log(2147483648 | 0)         // 2^31 wraps to the negative side -> -2147483648
console.log(2147483648 >>> 0)       // ToUint32 keeps it positive -> 2147483648
console.log(-2147483648 >>> 0)      // -> 2147483648
console.log(4294967295 >> 0)        // ToInt32(2^32-1) = -1
console.log(4294967295 >> 1)        // sign-extends -> -1
console.log(1 << 32)                // shift count masks to 0 -> 1
console.log(1 << 33)                // -> 2
console.log(1 << 64)                // 64 & 31 = 0 -> 1
console.log(NaN | 0)                // ToInt32(NaN) = 0
console.log(Infinity | 0)           // 0
console.log((0 - Infinity) >>> 0)   // ToUint32(-Infinity) = 0
}
__perf_run_core_unsigned_right_shift()

