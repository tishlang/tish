fn __perf_run_core_objects() {
// Comprehensive test: plain objects and property access
// Tests: literals, dot access, bracket access, nested objects, objects with functions
// NOTE: Tish uses null where JS uses undefined (Tish has no undefined type)

// Basic object creation
let pt = { x: 10, y: 20 }
console.log(pt.x)
console.log(pt.y)

// Bracket access with string literal
console.log(pt["x"])

// Dynamic property access
let propName = "y"
console.log(pt[propName])

// Multiple properties
let rec = { a: 1, b: 2, c: 3 }
console.log(rec.a, rec.b, rec.c)

// Nested objects
let nested = {
  outer: {
    inner: {
      value: 42
    }
  }
}
console.log(nested.outer.inner.value)
console.log(nested["outer"]["inner"]["value"])

// Mixed dot and bracket access
console.log(nested.outer["inner"].value)

// Objects with different value types
let mixed = {
  num: 123,
  str: "hello",
  bool: true,
  nil: null,
  arr: [1, 2, 3],
  obj: { nested: true }
}
console.log(mixed.num)
console.log(mixed.str)
console.log(mixed.bool)
console.log(mixed.nil)
console.log(mixed.arr[1])
console.log(mixed.obj.nested)

// Dynamic property access with bracket notation
let dynamicKey = "x"
console.log(pt[dynamicKey])

// Objects as function parameters
fn getX(obj) = obj.x
fn getY(obj) = obj.y
console.log(getX(pt))
console.log(getY(pt))

// Functions returning objects
fn makePoint(x, y) {
  return { x: x, y: y }
}
let p = makePoint(100, 200)
console.log(p.x, p.y)

// Object in conditional
let config = { enabled: true, count: 5 }
if (config.enabled)
  console.log("enabled with count:", config.count)

// Object in loop iteration (accessing properties)
let items = [
  { name: "a", val: 1 },
  { name: "b", val: 2 },
  { name: "c", val: 3 }
]
for (let item of items)
  console.log(item.name, item.val)

// typeof object
console.log(typeof {})
console.log(typeof { x: 1 })
console.log(typeof nested)

// Object equality (reference comparison)
let obj1 = { x: 1 }
let obj2 = { x: 1 }
let obj3 = obj1
console.log(obj1 === obj2)
console.log(obj1 === obj3)

// 'in' operator
let testIn = { a: 1, b: 2 }
console.log("a" in testIn)
console.log("c" in testIn)

// Optional chaining with objects
let maybeNull = null
console.log(maybeNull?.x)
let hasX = { x: 99 }
console.log(hasX?.x)

// Deep optional chaining
let deep = { a: { b: { c: 1 } } }
let shallow = { a: null }
console.log(deep?.a?.b?.c)
console.log(shallow?.a?.b?.c)

// Nullish coalescing with object properties
let withNull = { val: null }
let withValue = { val: 42 }
console.log(withNull.val ?? "default")
console.log(withValue.val ?? "default")
}
__perf_run_core_objects()

fn __perf_run_core_objects_perf() {
// Performance test: heavy object workload
// Stresses object creation, property access, and iteration

// Create mlet objects in a loop
let objects = []
for (let i = 0; i < 100; i = i + 1) {
  // Note: We can't do objects.push(), so we create arrays with spread would be needed
  // For now, test object creation and access patterns
}

// Deep property access chains
let data = {
  users: {
    admin: {
      profile: {
        name: "Admin",
        level: 10
      }
    },
    guest: {
      profile: {
        name: "Guest",
        level: 1
      }
    }
  }
}

// Repeated deep access (simulates hot path)
let sum = 0
for (let i = 0; i < 1000; i = i + 1) {
  sum = sum + data.users.admin.profile.level
  sum = sum + data.users.guest.profile.level
}
console.log("sum:", sum)

// Object property lookup with dynamic keys
let keys = ["a", "b", "c", "d", "e"]
let lookup = { a: 1, b: 2, c: 3, d: 4, e: 5 }
let total = 0
for (let k of keys) {
  total = total + lookup[k]
}
console.log("total:", total)

// Nested object traversal
let tree = {
  val: 1,
  left: {
    val: 2,
    left: { val: 4, left: null, right: null },
    right: { val: 5, left: null, right: null }
  },
  right: {
    val: 3,
    left: { val: 6, left: null, right: null },
    right: { val: 7, left: null, right: null }
  }
}

// Simple tree value access
console.log("root:", tree.val)
console.log("left:", tree.left.val)
console.log("right:", tree.right.val)
console.log("left-left:", tree.left.left.val)
console.log("left-right:", tree.left.right.val)
console.log("right-left:", tree.right.left.val)
console.log("right-right:", tree.right.right.val)

// Mlet small object creations
fn makeRecord(id, name, active) {
  return { id: id, name: name, active: active }
}

let records = [
  makeRecord(1, "Alice", true),
  makeRecord(2, "Bob", false),
  makeRecord(3, "Charlie", true),
  makeRecord(4, "Diana", true),
  makeRecord(5, "Eve", false)
]

let activeCount = 0
for (let r of records) {
  if (r.active)
    activeCount = activeCount + 1
}
console.log("active:", activeCount)

// Optional chaining performance
let maybeData = {
  level1: {
    level2: {
      level3: {
        value: 42
      }
    }
  }
}

let chainSum = 0
for (let i = 0; i < 500; i = i + 1) {
  chainSum = chainSum + (maybeData?.level1?.level2?.level3?.value ?? 0)
}
console.log("chainSum:", chainSum)

// 'in' operator performance
let checkObj = { a: 1, b: 2, c: 3, d: 4, e: 5, f: 6, g: 7, h: 8, i: 9, j: 10 }
let inCount = 0
let testKeys = ["a", "b", "z", "c", "d", "x", "e", "f", "y", "g"]
for (let i = 0; i < 100; i = i + 1) {
  for (let k of testKeys) {
    if (k in checkObj)
      inCount = inCount + 1
  }
}
console.log("inCount:", inCount)
}
__perf_run_core_objects_perf()

