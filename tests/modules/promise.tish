// Promise tests (requires http feature)

// new Promise(executor) — the PRIMARY JS form. This was broken on the VM until 2026-06-06
// (the Construct opcode routed to construct_builtin which only checked __construct, not __call;
// executor never ran, await returned null). First test so any regression fails immediately.
let p0 = new Promise((resolve, reject) => { resolve("new-ctor") })
let v0 = await p0
console.log("new Promise:", v0)

// Promise(executor) without new — also supported (goes through __call directly)
let p1 = Promise((resolve, reject) => { resolve(42) })
let v1 = await p1
console.log("Promise sync resolve:", v1)

// Promise.resolve
let p2 = Promise.resolve(100)
let v2 = await p2
console.log("Promise.resolve:", v2)

// Promise.reject
let ok = false
try {
  await Promise.reject("err")
} catch (e) {
  ok = (e === "err")
}
console.log("Promise.reject caught:", ok)

// .then chain
let p3 = Promise.resolve(1).then(x => x + 1).then(x => x * 2)
let v3 = await p3
console.log(".then chain:", v3)

// .catch (use bracket notation - catch is reserved)
let p4 = Promise.reject("fail")["catch"](e => "handled: " + e)
let v4 = await p4
console.log(".catch:", v4)

// Promise.all
let pa = Promise.all([Promise.resolve(1), Promise.resolve(2), Promise.resolve(3)])
let va = await pa
console.log("Promise.all:", va[0], va[1], va[2])

// Promise.race
let pr = Promise.race([Promise.resolve("fast"), Promise.resolve("slow")])
let vr = await pr
console.log("Promise.race:", vr)

// Promise.any (new) — first fulfilled wins
let pany = await Promise.any([
  new Promise((_, r) => r("skip")),
  new Promise((resolve) => resolve("any-win")),
])
console.log("Promise.any:", pany)

// Promise.allSettled (new) — never rejects, collects all
let ps = await Promise.allSettled([
  new Promise((resolve) => resolve(1)),
  new Promise((_, r) => r("reason")),
])
console.log("Promise.allSettled:", ps[0].status, ps[1].status, ps[1].reason)

console.log("Promise tests completed")
