// MVP test: parseInt, parseFloat, isFinite, isNaN, Infinity, NaN
print(parseInt("42"))
print(parseInt("  -123  "))
print(parseInt("3.14"))
print(parseFloat("3.14"))
print(parseFloat("  -2.5  "))
print(isFinite(1))
print(isFinite(Infinity))
print(isFinite(NaN))
print(isNaN(NaN))
print(isNaN(1))
print(Infinity)
print(NaN)
print(typeof Infinity)
print(typeof NaN)
