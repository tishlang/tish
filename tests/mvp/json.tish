// MVP test: JSON.parse and JSON.stringify
any obj = { x: 1, y: "hi", z: true }
any s = JSON.stringify(obj)
console.log(s)

any parsed = JSON.parse(s)
console.log(parsed.x)
console.log(parsed.y)
console.log(parsed.z)

any arr = [1, 2, "a"]
console.log(JSON.stringify(arr))

any arr2 = JSON.parse("[1,2,\"a\"]")
console.log(arr2[0])
console.log(arr2[1])
console.log(arr2[2])
