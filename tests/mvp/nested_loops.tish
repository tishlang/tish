// MVP test: nested loops - multiplication table, verify loop variable scope
any i = 0
any j = 0
for (any row = 1; row <= 3; row = row + 1) {
  for (any col = 1; col <= 3; col = col + 1) {
    console.log(row, "x", col, "=", row * col)
  }
}
console.log("i after loops:", i)
console.log("j after loops:", j)
