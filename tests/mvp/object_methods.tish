// Tests for Object.assign() and Object.fromEntries()

console.log("=== Object.assign() tests ===");

// Basic merge
let target = { a: 1, b: 2 };
let source = { b: 3, c: 4 };
let result = Object.assign(target, source);
console.log(result.a === 1);
console.log(result.b === 3);
console.log(result.c === 4);

// Target is modified in place
console.log(target.b === 3);
console.log(target.c === 4);

// Multiple sources
let t2 = { a: 1 };
let s1 = { b: 2 };
let s2 = { c: 3 };
let r2 = Object.assign(t2, s1, s2);
console.log(r2.a === 1);
console.log(r2.b === 2);
console.log(r2.c === 3);

// Clone object
let original = { x: 10, y: 20 };
let clone = Object.assign({}, original);
console.log(clone.x === 10);
console.log(clone.y === 20);

// Verify clone is separate
clone.x = 100;
console.log(original.x === 10);
console.log(clone.x === 100);

console.log("=== Object.fromEntries() tests ===");

// Basic fromEntries
let entries = [["a", 1], ["b", 2], ["c", 3]];
let obj = Object.fromEntries(entries);
console.log(obj.a === 1);
console.log(obj.b === 2);
console.log(obj.c === 3);

// With Object.entries round-trip
let src = { foo: "bar", baz: 42 };
let ents = Object.entries(src);
let rebuilt = Object.fromEntries(ents);
console.log(rebuilt.foo === "bar");
console.log(rebuilt.baz === 42);

console.log("=== All Object method tests passed ===");
