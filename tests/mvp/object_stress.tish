// Object manipulation stress tests
// Tests object operations at scale to identify bottlenecks

let start = 0;
let end = 0;

console.log("=== Object Stress Tests ===");
console.log("");

// === OBJECT CREATION ===
console.log("--- Object Creation ---");

start = Date.now();
for (let i = 0; i < 5000; i++) {
    let obj = {};
}
end = Date.now();
console.log("Empty object creation x5000: " + (end - start) + "ms");

start = Date.now();
for (let i = 0; i < 5000; i++) {
    let obj = { a: 1, b: 2, c: 3 };
}
end = Date.now();
console.log("3-prop literal x5000: " + (end - start) + "ms");

start = Date.now();
for (let i = 0; i < 5000; i++) {
    let obj = { a: 1, b: 2, c: 3, d: 4, e: 5, f: 6, g: 7, h: 8, i: 9, j: 10 };
}
end = Date.now();
console.log("10-prop literal x5000: " + (end - start) + "ms");

start = Date.now();
for (let i = 0; i < 5000; i++) {
    let x = i;
    let obj = { x: x, y: x + 1, z: x * 2 };
}
end = Date.now();
console.log("Computed props x5000: " + (end - start) + "ms");

// === PROPERTY ACCESS ===
console.log("");
console.log("--- Property Access ---");

let smallObj = { x: 1, y: 2, z: 3 };
let largeObj = { a: 1, b: 2, c: 3, d: 4, e: 5, f: 6, g: 7, h: 8, i: 9, j: 10,
                  k: 11, l: 12, m: 13, n: 14, o: 15, p: 16, q: 17, r: 18, s: 19, t: 20 };

start = Date.now();
for (let i = 0; i < 10000; i++) {
    let v = smallObj.x;
}
end = Date.now();
console.log("Dot access (first prop) x10000: " + (end - start) + "ms");

start = Date.now();
for (let i = 0; i < 10000; i++) {
    let v = smallObj.z;
}
end = Date.now();
console.log("Dot access (last of 3) x10000: " + (end - start) + "ms");

start = Date.now();
for (let i = 0; i < 10000; i++) {
    let v = largeObj.t;
}
end = Date.now();
console.log("Dot access (last of 20) x10000: " + (end - start) + "ms");

let key = "x";
start = Date.now();
for (let i = 0; i < 10000; i++) {
    let v = smallObj[key];
}
end = Date.now();
console.log("Bracket access x10000: " + (end - start) + "ms");

let keys = ["a", "j", "t"];
start = Date.now();
for (let i = 0; i < 3000; i++) {
    for (let k of keys) {
        let v = largeObj[k];
    }
}
end = Date.now();
console.log("Dynamic key access (3 keys x3000): " + (end - start) + "ms");

// === PROPERTY WRITE ===
console.log("");
console.log("--- Property Write ---");

let writeObj = { x: 0, y: 0, z: 0 };
start = Date.now();
for (let i = 0; i < 10000; i++) {
    writeObj.x = i;
}
end = Date.now();
console.log("Dot write x10000: " + (end - start) + "ms");

start = Date.now();
for (let i = 0; i < 10000; i++) {
    writeObj[key] = i;
}
end = Date.now();
console.log("Bracket write x10000: " + (end - start) + "ms");

start = Date.now();
for (let i = 0; i < 5000; i++) {
    let obj = {};
    obj.a = 1;
    obj.b = 2;
    obj.c = 3;
}
end = Date.now();
console.log("Dynamic prop add x5000: " + (end - start) + "ms");

// === DEEP NESTED ACCESS ===
console.log("");
console.log("--- Deep Nested Access ---");

let deep3 = { a: { b: { c: 42 } } };
let deep5 = { a: { b: { c: { d: { e: 42 } } } } };
let deep7 = { a: { b: { c: { d: { e: { f: { g: 42 } } } } } } };

start = Date.now();
for (let i = 0; i < 10000; i++) {
    let v = deep3.a.b.c;
}
end = Date.now();
console.log("3-level deep access x10000: " + (end - start) + "ms");

start = Date.now();
for (let i = 0; i < 10000; i++) {
    let v = deep5.a.b.c.d.e;
}
end = Date.now();
console.log("5-level deep access x10000: " + (end - start) + "ms");

start = Date.now();
for (let i = 0; i < 10000; i++) {
    let v = deep7.a.b.c.d.e.f.g;
}
end = Date.now();
console.log("7-level deep access x10000: " + (end - start) + "ms");

// === OPTIONAL CHAINING ===
console.log("");
console.log("--- Optional Chaining ---");

let maybeObj = { a: { b: { c: 42 } } };
let nullObj = { a: null };

start = Date.now();
for (let i = 0; i < 10000; i++) {
    let v = maybeObj?.a?.b?.c;
}
end = Date.now();
console.log("Optional chain (all exist) x10000: " + (end - start) + "ms");

start = Date.now();
for (let i = 0; i < 10000; i++) {
    let v = nullObj?.a?.b?.c;
}
end = Date.now();
console.log("Optional chain (short-circuit) x10000: " + (end - start) + "ms");

// === OBJECT SPREAD ===
console.log("");
console.log("--- Object Spread ---");

let base3 = { a: 1, b: 2, c: 3 };
let base10 = { a: 1, b: 2, c: 3, d: 4, e: 5, f: 6, g: 7, h: 8, i: 9, j: 10 };

start = Date.now();
for (let i = 0; i < 5000; i++) {
    let copy = { ...base3 };
}
end = Date.now();
console.log("Spread copy (3 props) x5000: " + (end - start) + "ms");

start = Date.now();
for (let i = 0; i < 5000; i++) {
    let copy = { ...base10 };
}
end = Date.now();
console.log("Spread copy (10 props) x5000: " + (end - start) + "ms");

start = Date.now();
for (let i = 0; i < 5000; i++) {
    let merged = { ...base3, d: 4, e: 5 };
}
end = Date.now();
console.log("Spread + extend x5000: " + (end - start) + "ms");

start = Date.now();
for (let i = 0; i < 3000; i++) {
    let merged = { ...base3, ...base10 };
}
end = Date.now();
console.log("Merge two objects x3000: " + (end - start) + "ms");

// === OBJECT.ASSIGN ===
console.log("");
console.log("--- Object.assign ---");

start = Date.now();
for (let i = 0; i < 5000; i++) {
    let target = {};
    Object.assign(target, base3);
}
end = Date.now();
console.log("assign to empty x5000: " + (end - start) + "ms");

start = Date.now();
for (let i = 0; i < 5000; i++) {
    let target = { x: 0 };
    Object.assign(target, base3, base10);
}
end = Date.now();
console.log("assign multiple sources x5000: " + (end - start) + "ms");

// === OBJECT.KEYS/VALUES/ENTRIES ===
console.log("");
console.log("--- Object.keys/values/entries ---");

start = Date.now();
for (let i = 0; i < 5000; i++) {
    Object.keys(base10);
}
end = Date.now();
console.log("Object.keys (10 props) x5000: " + (end - start) + "ms");

start = Date.now();
for (let i = 0; i < 5000; i++) {
    Object.values(base10);
}
end = Date.now();
console.log("Object.values (10 props) x5000: " + (end - start) + "ms");

start = Date.now();
for (let i = 0; i < 5000; i++) {
    Object.entries(base10);
}
end = Date.now();
console.log("Object.entries (10 props) x5000: " + (end - start) + "ms");

start = Date.now();
for (let i = 0; i < 5000; i++) {
    let entries = [["a", 1], ["b", 2], ["c", 3]];
    Object.fromEntries(entries);
}
end = Date.now();
console.log("Object.fromEntries x5000: " + (end - start) + "ms");

// === 'IN' OPERATOR ===
console.log("");
console.log("--- 'in' Operator ---");

start = Date.now();
for (let i = 0; i < 10000; i++) {
    let has = "a" in base10;
}
end = Date.now();
console.log("'in' existing key x10000: " + (end - start) + "ms");

start = Date.now();
for (let i = 0; i < 10000; i++) {
    let has = "z" in base10;
}
end = Date.now();
console.log("'in' missing key x10000: " + (end - start) + "ms");

// === DESTRUCTURING ===
console.log("");
console.log("--- Destructuring ---");

start = Date.now();
for (let i = 0; i < 5000; i++) {
    let { a, b, c } = base3;
}
end = Date.now();
console.log("Destructure 3 props x5000: " + (end - start) + "ms");

start = Date.now();
for (let i = 0; i < 5000; i++) {
    let { a, b, c, d, e, f, g, h, i: ii, j } = base10;
}
end = Date.now();
console.log("Destructure 10 props x5000: " + (end - start) + "ms");

// Rest in destructuring not supported, test simpler pattern
start = Date.now();
for (let i = 0; i < 3000; i++) {
    let { a, b, c, d, e } = base10;
}
end = Date.now();
console.log("Destructure 5 props x3000: " + (end - start) + "ms");

// === OBJECT ITERATION ===
console.log("");
console.log("--- Object Iteration ---");

start = Date.now();
for (let i = 0; i < 2000; i++) {
    for (let k of Object.keys(base10)) {
        let v = base10[k];
    }
}
end = Date.now();
console.log("for-of Object.keys x2000: " + (end - start) + "ms");

start = Date.now();
for (let i = 0; i < 2000; i++) {
    for (let entry of Object.entries(base10)) {
        let x = entry[0] + entry[1];
    }
}
end = Date.now();
console.log("for-of Object.entries x2000: " + (end - start) + "ms");

// === FACTORY PATTERNS ===
console.log("");
console.log("--- Factory Patterns ---");

fun createUser(id, name) {
    return { id: id, name: name, active: true, createdAt: Date.now() };
}
start = Date.now();
for (let i = 0; i < 3000; i++) {
    createUser(i, "user" + i);
}
end = Date.now();
console.log("Factory function x3000: " + (end - start) + "ms");

fun createWithValue(val) {
    return { value: val, doubled: val * 2 };
}
start = Date.now();
for (let i = 0; i < 2000; i++) {
    let obj = createWithValue(i);
    let v = obj.value;
    let d = obj.doubled;
}
end = Date.now();
console.log("Factory + access x2000: " + (end - start) + "ms");

console.log("");
console.log("=== Object Stress Tests Complete ===");
