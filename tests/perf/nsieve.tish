// GAUNTLET: Sieve of Eratosthenes (Are We Fast Yet / SunSpider access-nsieve). Large boolean-array
// allocation + a strided write/scan loop with branch — stresses array growth, element writes, and
// branch prediction over integer indices. Valid in both tish and node; integer check (prime count).
function nsieve(n) {
  let isPrime = []
  for (let i = 0; i < n; i++) { isPrime.push(true) }
  let count = 0
  for (let i = 2; i < n; i++) {
    if (isPrime[i]) {
      count = count + 1
      let k = i + i
      while (k < n) {
        isPrime[k] = false
        k = k + i
      }
    }
  }
  return count
}

let t0 = Date.now()
// Run a few sizes (the classic nsieve repeats at 2^k * baseline); sum the counts for the check.
let total = 0
for (let r = 0; r < 8; r++) { total = total + nsieve(1000000) }
console.log("GAUNTLET nsieve " + (Date.now() - t0) + " " + total)
